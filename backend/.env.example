# Copy to .env in this directory. Backend reads from backend/.env.
# Mirrors the root .env.example — keep them in sync.

DATABASE_URL=postgresql+psycopg2://invoice_admin:dev_password_change_me@localhost:5432/invoice_automation

JWT_SECRET_KEY=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=invoices@yourbusiness.com
SMTP_FROM_NAME=Your Business

BUSINESS_NAME=Your Business Name
BUSINESS_ADDRESS=123 Example St, City, Country
BUSINESS_EMAIL=contact@yourbusiness.com
BUSINESS_PHONE=+00 000 000 0000

FRONTEND_ORIGIN=http://localhost:5173
